{
  "brand_identity": {
    "name": "LexAequitas",
    "archetype": "The Sovereign Guardian",
    "tone": "Authoritative, Precise, Just, Immersive",
    "visual_mood": "Cinematic Legal Drama meets High-Frequency Trading Terminal",
    "theme_mode": "System (Default Dark for Simulation, Light for Documents)"
  },
  "typography": {
    "headings": {
      "family": "Playfair Display",
      "weights": ["400", "600", "700"],
      "usage": "Landing page heros, section titles, formal legal headers",
      "tracking": "-0.02em"
    },
    "body": {
      "family": "Manrope",
      "weights": ["400", "500", "600"],
      "usage": "General UI, reading content, dashboard cards",
      "tracking": "normal"
    },
    "mono": {
      "family": "JetBrains Mono",
      "weights": ["400", "500"],
      "usage": "Case IDs, Timestamps, Court Transcripts, Code Snippets",
      "tracking": "normal"
    },
    "scale_ratios": {
      "h1": "text-5xl md:text-7xl leading-tight font-serif",
      "h2": "text-3xl md:text-5xl leading-tight font-serif",
      "h3": "text-2xl md:text-3xl font-serif",
      "body-lg": "text-lg leading-relaxed",
      "body-base": "text-base leading-relaxed",
      "caption": "text-xs uppercase tracking-widest text-muted-foreground"
    }
  },
  "colors": {
    "primary": {
      "name": "Sovereign Navy",
      "hex": "#0F172A",
      "tailwind": "bg-slate-900",
      "usage": "Main backgrounds, Sidebar, Headers"
    },
    "secondary": {
      "name": "Justitia Gold",
      "hex": "#D4AF37",
      "tailwind": "text-yellow-600",
      "usage": "Accents, Borders, Key Actions, 'Win' states"
    },
    "accent_danger": {
      "name": "Objection Red",
      "hex": "#EF4444",
      "tailwind": "text-red-500",
      "usage": "Risks, Deadlines, Objections"
    },
    "accent_success": {
      "name": "Compliance Emerald",
      "hex": "#10B981",
      "tailwind": "text-emerald-500",
      "usage": "Approved status, Compliance clear"
    },
    "neutral": {
      "surface_light": "#F8FAFC",
      "surface_dark": "#020617",
      "border": "#E2E8F0"
    },
    "gradients": {
      "hero_glow": "radial-gradient(circle at 50% 0%, rgba(212, 175, 55, 0.15) 0%, rgba(15, 23, 42, 0) 70%)",
      "gold_border": "linear-gradient(90deg, transparent, #D4AF37, transparent)"
    }
  },
  "layout_strategies": {
    "marketing": {
      "grid_type": "Tetris Grid (Mode A)",
      "spacing": "Generous (p-8 to p-24)",
      "container_style": "Sharp edges, 1px gold borders with low opacity"
    },
    "dashboard": {
      "grid_type": "High Density Bento (Mode B)",
      "spacing": "Compact (gap-4, p-6)",
      "card_style": "Flat background, 1px border-border, no shadow by default"
    },
    "simulation_courtroom": {
      "structure": "Three-Pane Cockpit",
      "left_panel": {
        "width": "25%",
        "content": "User Strategy & Arguments",
        "style": "Glassmorphism Dark"
      },
      "center_panel": {
        "width": "50%",
        "content": "Visual Courtroom & Transcript Stream",
        "style": "Cinematic Focus"
      },
      "right_panel": {
        "width": "25%",
        "content": "Evidence Viewer & AI Opponent Moves",
        "style": "Glassmorphism Dark"
      }
    }
  },
  "component_styling": {
    "radius": "rounded-sm",
    "shadows": "shadow-none",
    "borders": "border-slate-200 dark:border-slate-800",
    "glass_effect": "backdrop-blur-xl bg-slate-900/80 border border-white/10",
    "buttons": {
      "primary": "bg-[#0F172A] text-white hover:bg-[#1E293B] rounded-none uppercase tracking-wide text-xs font-bold px-6 py-3 border-b-2 border-[#D4AF37]",
      "secondary": "bg-transparent border border-slate-300 text-slate-900 hover:bg-slate-50 rounded-none uppercase tracking-wide text-xs font-bold px-6 py-3"
    },
    "inputs": {
      "style": "rounded-none border-slate-300 focus:border-[#D4AF37] focus:ring-1 focus:ring-[#D4AF37] bg-transparent"
    }
  },
  "image_assets": {
    "hero_background": {
      "url": "https://images.unsplash.com/photo-1758833502047-8f1c7dc5edd7",
      "alt": "Abstract Cinematic Law Office",
      "usage": "Landing Page Hero Background with heavy dark overlay"
    },
    "courtroom_preview": {
      "url": "https://images.unsplash.com/photo-1769029265788-d7921a103403",
      "alt": "Gavel on Judge's Bench",
      "usage": "Simulation Start Screen / Feature Highlight"
    },
    "services_litigation": {
      "url": "https://images.unsplash.com/photo-1589994965851-a8f479c573a9",
      "alt": "Lady Justice Statue Bronze",
      "usage": "Services Page - Litigation Card"
    },
    "dashboard_user": {
      "url": "https://images.unsplash.com/photo-1770048532712-4fde5ef7eb90",
      "alt": "Professional working on laptop",
      "usage": "User Profile / Dashboard Header"
    },
    "document_center": {
      "url": "https://images.unsplash.com/photo-1761322572550-967ea8c0bfd9",
      "alt": "Legal Documents Notebook",
      "usage": "Document Center Header"
    }
  },
  "motion_guidelines": {
    "transitions": "transition-all duration-300 ease-[cubic-bezier(0.25,1,0.5,1)]",
    "micro_interactions": {
      "hover_lift": "hover:-translate-y-1 hover:shadow-lg",
      "button_press": "active:scale-95"
    },
    "page_load": {
      "initial": { "opacity": 0, "y": 20 },
      "animate": { "opacity": 1, "y": 0 },
      "transition": { "duration": 0.6 }
    }
  },
  "visual_enhancers": {
    "noise_texture": "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E\")",
    "gold_shimmer": "Background animation for premium buttons",
    "scanlines": "Overlay for the 'Defense AI' video feed to make it look like a security feed"
  },
  "iconography": {
    "library": "lucide-react",
    "style": "Stroke width 1.5px (Thin/Elegant)",
    "usage": {
      "court": "Gavel",
      "documents": "FileText",
      "alerts": "Siren",
      "dashboard": "LayoutDashboard",
      "user": "Scale"
    }
  },
  "universal_guidelines_for_main_agent": [
    "DO NOT use gradients for backgrounds unless it's a subtle radial glow.",
    "Dark colors must be matte, not glossy.",
    "Use 'Inter' ONLY if explicitly necessary; prefer 'Manrope' for UI.",
    "Buttons should be sharp (rounded-none or rounded-sm) to convey legal precision.",
    "Use 'sonner' for toasts.",
    "Ensure high contrast text (WCAG AA).",
    "Never center text in the marketing body; keep it left-aligned for readability.",
    "Use 'data-testid' on all interactive elements."
  ]
}